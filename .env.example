# Copy to .env.local for local development (.env.local is gitignored).
# On Vercel, set these in Project → Settings → Environment Variables instead.

# ── Backend API ────────────────────────────────────────────────────────────
# Origin the server-side proxy (app/api/[...path]/route.ts) forwards to. The
# browser only ever calls this app's own /api/* — the backend URL stays
# server-side, so there's no CORS and the backend host is never shipped to the
# browser. The proxy appends /api/<route>, so point this at the origin (and base
# path, if any) that serves the FastAPI /api/* routes.
#
#   local dev : http://localhost:8000                     (uvicorn dev server)
#   prod      : https://sdev.autosquared.com/leasing-admin (host nginx → container)
API_ORIGIN=http://localhost:8000

# Shared secret sent as the X-Lease-Admin-Secret header to the backend. The
# droplet's nginx requires it on /leasing-admin/, so only this server-side proxy
# (never the browser) can reach the admin API. Leave unset for local dev.
# API_PROXY_SECRET=

# ── Auth ───────────────────────────────────────────────────────────────────
# "supabase" turns on the login gate + per-request session check in the proxy.
# Anything else leaves the app open (fine for local dev).
NEXT_PUBLIC_AUTH_MODE=disabled
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
